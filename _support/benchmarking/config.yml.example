  - name: gitlab
    include_in_test: true
    reference_backend: files
    remote: "https://gitlab.com/gitlab-org/gitlab.git"
    revision: "8f3978675aa4df643cff5a01a8e1896ae754685a"
    testdata:
      commits:
        - "875ffb690e25eb8c98797b5641c6c16c71454b73"
