#!/bin/sh

if [ -z "$EXPERIMENT" ]
then
    echo "EXPERIMENT must be set to one of the directory names under experiments/"
    exit 1
fi

if [ -z "$SETUP" ]
then
    SETUP=vm
fi

case "$SETUP" in
  "vm"|"kubernetes")
    :
    ;;
  *)
    echo "SETUP '$SETUP' must be 'vm' or 'kubernetes'"
    exit 1
    ;;
esac

exec ansible-playbook \
    -i experiments/"${EXPERIMENT}"/hosts.ini destroy.yml \
    -e "gitaly_benchmarking_experiment_name=${EXPERIMENT}" \
    -e "gitaly_benchmarking_setup=${SETUP}" "$@"
